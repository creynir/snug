{
  "name": "snug-cli",
  "version": "0.2.0",
  "description": "Lightweight layout diagnostics for AI agents. Math instead of pixels.",
  "type": "module",
  "bin": {
    "snug": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "check": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check 'src/**/*.ts'"
  },
  "keywords": [
    "layout",
    "diagnostics",
    "headless",
    "ai",
    "agents"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "puppeteer": "^24.0.0",
    "yaml": "^2.7.0",
    "yargs": "^17.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/yargs": "^17.0.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  }
}
