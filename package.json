{
  "name": "snug",
  "version": "0.1.0",
  "description": "Lightweight layout diagnostics for AI agents. Math instead of pixels.",
  "type": "module",
  "bin": {
    "snug": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
